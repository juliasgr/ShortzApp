<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Perfil | Shortz-App</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>

   

               <div class="container mt-5">
<div class="row justify-content-center">
<div class="col-md-8 col-lg-6">
<div class="profile-card p-4">
<h2 class="fw-bold mb-4 text-center">Editar Perfil</h2>
<form action="/profile/edit" method="POST" enctype="multipart/form-data">
<div class="text-center mb-4">
<img src="<%= user.profilePicture ?
'/uploads/avatars/' + user.profilePicture :
'/images/default-profile.png' %>"
alt="Foto de Perfil" class="avatar-preview" id="profileImagePreview">
<div class="mt-3">
<label for="profilePicture" class="btn btn-outline-primary btn-sm">
<i class="bi bi-camera me-2"></i> Alterar Foto
</label>
<input type="file" id="profilePicture" name="profilePicture" accept="image/*" class="d-none">
</div>
</div>
<div class="mb-3">
<label for="username" class="form-label">Nome de Usuário</label>
<input type="text" class="form-control" id="username" name="username" value="<%= user.username %>" disabled>
</div>
<div class="mb-3">
<label for="fullName" class="form-label">Nome Completo</label>
<input type="text" class="form-control" id="fullName" name="fullName" value="<%= user.fullName %>">
</div>
<div class="mb-3">
<label for="bio" class="form-label">Bio</label>
<textarea class="form-control" id="bio" name="bio" rows="3" maxlength="255"><%= user.bio %></textarea>
<div id="bioHelp" class="form-text text-end"><span id="charCount">
<%= user.bio ? user.bio.length : 0 %></span>/255</div>
</div>
<div class="d-grid gap-2">
<button type="submit" class="btn btn-primary btn-lg">Salvar Alterações</button>
<a href="/feed" class="btn btn-outline-secondary btn-lg">Cancelar</a>
</div>
</form>
</div>
</div>
</div>
</div>
<script>
// Script para preview da imagem de perfil
document.getElementById("profilePicture").addEventListener("change", function (e) {
if (e.target.files && e.target.files[0]) {
var reader = new FileReader();
reader.onload = function (event) {
document.getElementById("profileImagePreview").src = event.target.result;
};
reader.readAsDataURL(e.target.files[0]);
}
});
// Script para contador de caracteres da bio
const bioTextarea = document.getElementById("bio");
const charCountSpan = document.getElementById("charCount");
bioTextarea.addEventListener("input", function () {
charCountSpan.textContent = this.value.length;
});
</script>
    </main>


    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Preview da imagem antes do upload
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imgPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Contador de caracteres para a bio
        const bio = document.getElementById('bio');
        const charCount = document.getElementById('charCount');

        bio.addEventListener('input', () => {
            charCount.textContent = `${bio.value.length}/255`;
        });

        // Inicializar contador
        charCount.textContent = `${bio.value.length}/255`;
    </script>
</body>

</html>